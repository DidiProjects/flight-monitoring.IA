{
  "name": "scraping-api",
  "version": "1.0.0",
  "description": "scraping.API — HTTP scraping API for Azul Airlines",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node dist/main.cjs",
    "dev": "tsx --watch src/main.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --minify --outfile=dist/main.cjs --external:playwright --external:camoufox-js --external:pino --external:pino-pretty --external:pino-loki",
    "postinstall": "npx camoufox-js fetch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "camoufox-js": "^0.10.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.2",
    "p-queue": "^8.1.0",
    "pino": "^9.6.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.59.1",
    "rebrowser-playwright": "^1.52.0",
    "tsx": "^4.19.4",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.19.17",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  }
}
