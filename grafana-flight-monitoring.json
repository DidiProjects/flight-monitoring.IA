{
  "timezone": "America/Sao_Paulo",
  "editable": true,
  "graphTooltip": 0,
  "fiscalYearStartMonth": 0,
  "schemaVersion": 41,
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Fonte Loki",
        "query": "loki"
      },
      {
        "type": "custom",
        "name": "level_scraping",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Nível — scraping.API",
        "query": ".*,error,warning,info,debug",
        "current": {
          "text": "Todos",
          "value": ".*",
          "selected": true
        },
        "options": [
          {
            "selected": true,
            "text": "Todos",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "warning",
            "value": "warning"
          },
          {
            "selected": false,
            "text": "info",
            "value": "info"
          },
          {
            "selected": false,
            "text": "debug",
            "value": "debug"
          }
        ]
      },
      {
        "type": "custom",
        "name": "level_api",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Nível — flight.API",
        "query": ".*,error,warning,info,debug",
        "current": {
          "text": "Todos",
          "value": ".*",
          "selected": true
        },
        "options": [
          {
            "selected": true,
            "text": "Todos",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "warning",
            "value": "warning"
          },
          {
            "selected": false,
            "text": "info",
            "value": "info"
          },
          {
            "selected": false,
            "text": "debug",
            "value": "debug"
          }
        ]
      },
      {
        "type": "textbox",
        "name": "search",
        "skipUrlSync": false,
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30,
        "label": "Busca nos logs",
        "query": ""
      }
    ]
  },
  "annotations": {},
  "title": "Flight Monitoring — Observabilidade",
  "uid": "flight-monitoring-logs",
  "tags": [
    "flight-monitoring",
    "logs",
    "loki"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "weekStart": "sunday",
  "preload": false,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "scraping.API — Logs & Métricas",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Logs — scraping.API",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 17,
        "h": 24
      },
      "targets": [
        {
          "expr": "{app=\"scraping-api\", level=~\"$level_scraping\"} |= `$search` | json",
          "refId": "A",
          "legendFormat": "",
          "range": true
        }
      ],
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Erros por Airline",
      "description": "Uma curva por airline. Novas airlines surgem automaticamente.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 17,
        "y": 1,
        "w": 7,
        "h": 12
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "axisLabel": "acumulado",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "cumulativeFunctions",
            "cumulative": {
              "field": ""
            },
            "replaceFields": true
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (airline) (count_over_time({app=\"scraping-api\", level=\"error\"} | json | airline != \"\" [$__interval]))",
          "refId": "A",
          "legendFormat": "{{airline}}",
          "range": true
        }
      ]
    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Warnings por Airline",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 17,
        "y": 13,
        "w": 7,
        "h": 12
      },
      "fieldConfig": {
        "defaults": {
