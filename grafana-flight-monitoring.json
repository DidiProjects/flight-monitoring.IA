          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "cumulativeFunctions",
            "cumulative": {
              "field": ""
            },
            "replaceFields": true
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (airline) (count_over_time({app=\"scraping-api\", level=\"warning\"} | json [$__interval]))",
          "refId": "A",
          "legendFormat": "{{airline}}",
          "range": true
        }
      ]
    },
    {
      "type": "row",
      "collapsed": false,
      "id": 0,
      "panels": [],
      "title": "flight.API — Logs & Métricas",
      "gridPos": {
        "x": 0,
        "y": 37,
        "h": 1,
        "w": 24
      }
    },
    {
      "type": "logs",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Logs — flight.API",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 17,
        "h": 24
      },
      "targets": [
        {
          "expr": "{app=\"flight-api\", level=~\"$level_api\"} |= `$search` | json",
          "refId": "A",
          "legendFormat": "",
