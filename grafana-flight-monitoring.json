    },
    {
      "type": "timeseries",
      "transparent": false,
      "repeatDirection": "h",
      "title": "Erros & Warnings",
      "description": "",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "x": 17,
        "y": 27,
        "w": 7,
        "h": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "axisLabel": "acumulado",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "warning"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9900",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "cumulativeFunctions",
            "cumulative": {
              "field": ""
            },
            "replaceFields": true
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"flight-api\", level=~\"error|warning\"} [$__interval]))",
          "refId": "A",
          "legendFormat": "{{level}}",
          "range": true
        }
      ]
    }
